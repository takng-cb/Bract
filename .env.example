# =================================================================
# Bract CRM - Environment Variables Template
# =================================================================
# Copy this file to `.env.local` (which is gitignored) and fill in
# the real values. Each worktree needs its own `.env.local`.
# 詳細: AGENTS.md / README.md / docs/architecture.md

# ─── Database (Neon Postgres) ───────────────────────────────────
# Neon Console → 該当プロジェクト → Connection Details → Pooled connection
# 形式: postgresql://<user>:<password>@<host>/neondb?sslmode=require
# 業種ごとに別 Neon プロジェクト (AGENTS.md「接続先 Neon 一覧」参照):
#   - real-estate: ep-soft-poetry-ao4xdfqm
#   - auto-body:   ep-young-meadow-aoo7z9eq
#   - base:        ep-proud-band-ao22d0oc
DATABASE_URL=

# ─── App ─────────────────────────────────────────────────────────
# 業種オーバーレイ: base / real-estate / auto-body のいずれか
# 未設定時は base 扱い。Vercel project ごとに別 value を設定する。
NEXT_PUBLIC_INDUSTRY=base

# 自分自身のオリジン URL
#   - ローカル開発: http://localhost:3000
#   - Vercel 本番:  https://<vercel-domain>
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Supabase (Auth + Storage 専用) ──────────────────────────────
# Supabase Dashboard → Settings → API
# プロジェクト URL（公開可）
NEXT_PUBLIC_SUPABASE_URL=

# anon key（クライアント SDK 用、公開可）
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# service_role key（サーバー側のみ。RLS バイパス権限を持つため絶対に
# クライアントに露出させないこと。Vercel project の env でも
# Production / Preview スコープに限定推奨）
SUPABASE_SERVICE_ROLE_KEY=

# ─── AI 機能フラグ（追加料金プラン）──────────────────────────────
# AI 活動まとめ機能を有効化する。Bract 側 (販売元) が契約に応じて
# Vercel project の env でセットする運用。顧客 (CRM 管理者) からは
# UI 経由でトグル不可。
#   - true / 1 / yes / on / enabled で有効
#   - 未設定 / false / 0 等で無効（UI 非表示、サーバー API も拒否）
#
# 有効化後は /admin/ai でプロバイダ (Groq / Gemini / Anthropic) と
# API キー、モデル、プロンプトを管理者が設定する。
AI_FEATURE_ENABLED=
