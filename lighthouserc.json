{
  "//": "Lighthouse CI 設定。Issue #40 Sprint 3。主要 4 ページに対し Performance / Accessibility / Best Practices / SEO スコアを計測。",
  "ci": {
    "collect": {
      "url": [
        "https://bract-crm.vercel.app/login",
        "https://bract-crm.vercel.app/forgot-password",
        "https://bract-crm.vercel.app/manifest.webmanifest",
        "https://bract-crm.vercel.app/"
      ],
      "numberOfRuns": 1,
      "settings": {
        "preset": "desktop"
      }
    },
    "//assert": "未認証ページのみ計測のため、絶対スコアではなく回帰検知（差分監視）に使う。閾値は緩めに設定し、80 を切ったら警告。",
    "assert": {
      "preset": "lighthouse:recommended",
      "assertions": {
        "categories:performance":     ["warn", { "minScore": 0.80 }],
        "categories:accessibility":   ["warn", { "minScore": 0.85 }],
        "categories:best-practices":  ["warn", { "minScore": 0.85 }],
        "categories:seo":             ["warn", { "minScore": 0.85 }],
        "uses-http2":                 "off",
        "uses-long-cache-ttl":        "off",
        "csp-xss":                    "off"
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
